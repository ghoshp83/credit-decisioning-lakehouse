# Environment reference for credit-decisioning-lakehouse.
# Copy to .env (gitignored) and fill in, or just `export` these in your shell.
# NEVER commit real values -- secrets are read from the environment, never from
# tracked files (see profiles.yml.example). This file lists placeholders only.

# --- Databricks connection (required for every live path: dbt, ML, AI) ---
DATABRICKS_HOST=adb-xxxx.cloud.databricks.com      # workspace host, no https://
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxx      # SQL warehouse HTTP path
# Short-lived PAT. Mint just before a live run and revoke right after:
#   databricks tokens create --lifetime-seconds 86400 -p <profile>
#   databricks tokens delete <token-id> -p <profile>
DATABRICKS_TOKEN=dapi-your-short-lived-token

# --- dbt targets (defaults shown; override only to point at another schema) ---
DBT_CATALOG=workspace            # Unity Catalog catalog for all outputs
DBT_SCHEMA=credit_dev            # dbt build schema (marts land in <schema>_marts)
DBT_RAW_CATALOG=workspace        # catalog holding the raw Home Credit tables
DBT_RAW_SCHEMA=home_credit_raw   # bronze schema the raw CSVs were loaded into
DBT_ML_SCHEMA=credit_ml          # schema the model-output Delta source lives in

# --- Python helpers (ml/ and ai/ read these directly) ---
MART_SCHEMA=credit_dev_marts     # gold marts schema (ml/pull_features, ai/nl_to_sql)
ML_SCHEMA=credit_ml              # where ml/shap_drivers writes pd_predictions
