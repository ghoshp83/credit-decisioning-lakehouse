[sqlfluff]
# Lint offline with the jinja templater + dbt builtins: dbt-databricks opens a
# live warehouse connection even to compile, so the `dbt` templater cannot run
# in CI without a real Databricks. apply_dbt_builtins stubs ref()/source()/etc.
templater = jinja
dialect = databricks
max_line_length = 120
exclude_rules = RF04

[sqlfluff:indentation]
# Jinja block tags ({% if is_incremental() %} ... {% endif %} around an
# incremental filter) should not add an indentation level to the SQL they
# wrap, otherwise the reflow rule flags a false positive on the where clause.
template_blocks_indent = false

[sqlfluff:templater:jinja]
apply_dbt_builtins = true
# Load our own macros (e.g. safe_divide) so the jinja templater can render
# model SQL that calls them; without this they read as undefined variables.
load_macros_from_path = macros

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.identifiers]
extended_capitalisation_policy = lower
